# Leave VITE_API_URL empty to use the Vite dev proxy (/api -> backend :8000).
# Set it to an absolute URL (e.g. http://localhost:8000/api) to bypass the proxy.
VITE_API_URL=

# Google OAuth client id (for later — dev fake-login is used for now)
VITE_GOOGLE_CLIENT_ID=

# Show the dev fake-login selector on the login screen
VITE_DEV_FAKE_AUTH=true
